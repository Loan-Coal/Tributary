# Copy to .env (gitignored) and fill in the values for your setup.
# Must match your running Neo4j container's NEO4J_AUTH.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# LLM backend: "ollama" | "qwen" | "claude"
TRIBUTARY_LLM=ollama

# Ollama (no API key needed — Ollama runs locally)
TRIBUTARY_OLLAMA_MODEL=qwen3:8b
# TRIBUTARY_OLLAMA_URL=http://localhost:11434

# Claude (requires API key)
# ANTHROPIC_API_KEY=sk-ant-...

# Qwen via HuggingFace transformers (requires torch + transformers installed)
# TRIBUTARY_QWEN_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
